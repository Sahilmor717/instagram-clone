<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat with <%= otherUser.username %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-white flex">

    <%- include('../partials/sidebar') %>

    <div class="flex-grow ml-16 xl:ml-64 flex flex-col h-screen border-l bg-white">
        <div class="flex items-center justify-between p-4 border-b">
            <div class="flex items-center gap-3">
                <a href="/messages" class="md:hidden">⬅️</a>
                <div class="w-8 h-8 rounded-full overflow-hidden border">
                    <img src="<%= otherUser.profilePic %>" class="w-full h-full object-cover">
                </div>
                <span class="font-bold text-sm"><%= otherUser.username %></span>
            </div>
            <button class="text-xl">ℹ️</button>
        </div>

        <div id="chat-box" class="flex-grow overflow-y-auto p-4 space-y-4 no-scrollbar">
            <% messages.forEach(msg => { %>
                <div class="flex <%= msg.sender.toString() === user._id.toString() ? 'justify-end' : 'justify-start' %>">
                    <div class="<%= msg.sender.toString() === user._id.toString() ? 'bg-blue-500 text-white rounded-tr-none' : 'bg-gray-100 text-black rounded-tl-none' %> px-4 py-2 rounded-2xl max-w-[70%] text-sm shadow-sm">
                        <%= msg.text %>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="p-4 bg-white">
            <div class="flex items-center gap-3 border rounded-full px-4 py-2 focus-within:border-gray-400">
                <button class="text-xl">😊</button>
                <input type="text" id="msg-input" placeholder="Message..." class="flex-grow outline-none text-sm bg-transparent">
                <button onclick="sendMessage()" class="text-blue-500 font-bold text-sm hover:text-blue-700 transition">Send</button>
            </div>
        </div>
    </div>

    <script>
        const socket = io();
        const me = "<%= user._id %>";
        const them = "<%= otherUser._id %>";
        const chatBox = document.getElementById('chat-box');

        // Scroll to bottom immediately
        chatBox.scrollTop = chatBox.scrollHeight;

        function sendMessage() {
            const input = document.getElementById('msg-input');
            const text = input.value;
            if(!text.trim()) return;

            // Emit to server
            socket.emit('privateMessage', { 
                senderId: me, 
                receiverId: them, 
                text: text 
            });

            input.value = '';
        }

        // Listen for incoming messages
        socket.on('receiveMessage', (data) => {
            // Check if message belongs to this conversation
            if ((data.senderId === me && data.receiverId === them) || (data.senderId === them && data.receiverId === me)) {
                const div = document.createElement('div');
                const isMe = data.senderId === me;
                
                div.className = `flex ${isMe ? 'justify-end' : 'justify-start'}`;
                div.innerHTML = `
                    <div class="${isMe ? 'bg-blue-500 text-white rounded-tr-none' : 'bg-gray-100 text-black rounded-tl-none'} px-4 py-2 rounded-2xl max-w-[70%] text-sm shadow-sm">
                        ${data.text}
                    </div>
                `;
                
                chatBox.appendChild(div);
                chatBox.scrollTop = chatBox.scrollHeight; // Auto-scroll
            }
        });

        // Send on Enter key
        document.getElementById('msg-input').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });
    </script>

    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</body>
</html>