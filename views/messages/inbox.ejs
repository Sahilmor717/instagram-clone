<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inbox • Chats</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white flex">

    <%- include('../partials/sidebar') %>

    <div class="flex-grow ml-16 xl:ml-64 flex min-h-screen border-l">
        <div class="w-full md:w-80 border-r flex flex-col">
            <div class="p-5 border-b flex justify-between items-center">
                <h1 class="text-xl font-bold"><%= user.username %></h1>
                <span>📝</span>
            </div>

            <div class="overflow-y-auto">
                <h3 class="px-5 py-3 font-semibold text-sm">Messages</h3>
                <% if(chatPartners && chatPartners.length > 0) { %>
                    <% chatPartners.forEach(partner => { %>
                        <a href="/messages/chat/<%= partner._id %>" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition">
                            <img src="<%= partner.profilePic %>" class="w-12 h-12 rounded-full object-cover">
                            <div>
                                <p class="text-sm font-semibold"><%= partner.username %></p>
                                <p class="text-xs text-gray-500">Click to chat</p>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <p class="p-5 text-gray-500 text-sm">Follow people to start chatting!</p>
                <% } %>
            </div>
        </div>

        <div class="hidden md:flex flex-grow flex-col items-center justify-center text-center">
            <div class="w-20 h-20 border-2 border-black rounded-full flex items-center justify-center text-3xl mb-4">
                ✉️
            </div>
            <h2 class="text-xl font-semibold">Your Messages</h2>
            <p class="text-gray-500 text-sm">Send private photos and messages to a friend.</p>
            <button class="mt-4 bg-blue-500 text-white px-4 py-2 rounded-lg font-semibold text-sm">Send Message</button>
        </div>
    </div>

</body>
</html>