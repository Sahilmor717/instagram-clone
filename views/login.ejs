<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram - Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex flex-col justify-center items-center h-screen">
    <div class="bg-white border border-gray-300 w-80 py-8 flex flex-col items-center mb-3">
        <h1 class="text-4xl font-serif mb-6 mt-4">Instagram</h1>
        <form action="/login" method="POST" class="w-64 flex flex-col">
            <input type="text" name="username" placeholder="Username" required class="text-xs w-full mb-2 border border-gray-300 rounded bg-gray-50 px-2 py-2 focus:outline-none focus:border-gray-400">
            <input type="password" name="password" placeholder="Password" required class="text-xs w-full mb-4 border border-gray-300 rounded bg-gray-50 px-2 py-2 focus:outline-none focus:border-gray-400">
            <button type="submit" class="bg-blue-500 text-white font-semibold py-1.5 rounded text-sm mb-4">Log in</button>
        </form>
    </div>
    <div class="bg-white border border-gray-300 w-80 py-4 flex justify-center">
        <p class="text-sm">Don't have an account? <a href="/register" class="text-blue-500 font-semibold">Sign up</a></p>
    </div>
</body>
</html>