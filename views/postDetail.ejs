<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post by <%= post.user.username %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-white flex overflow-hidden">

    <%- include('partials/sidebar') %>

    <div class="flex-grow ml-16 xl:ml-64 flex flex-col items-center justify-center min-h-screen bg-neutral-50 relative">
        
        <div class="absolute top-0 w-full p-4 flex justify-between items-center bg-white border-b z-10 px-10">
            <button onclick="window.history.back()" class="flex items-center gap-2 text-gray-600 hover:text-black transition">
                <span class="text-xl">←</span> 
                <span class="font-medium text-sm">Back to Profile</span>
            </button>
            
            <% if(nextPostId) { %>
                <a href="/post/<%= nextPostId %>" class="flex items-center gap-2 text-blue-500 hover:text-blue-700 transition">
                    <span class="font-medium text-sm">Next Post</span>
                    <span class="text-xl">→</span>
                </a>
            <% } else { %>
                <span class="text-gray-300 text-sm font-medium">End of Posts</span>
            <% } %>
        </div>

        <div class="bg-white border rounded shadow-sm flex flex-col md:flex-row w-[95%] max-w-5xl h-[80vh] mt-10 overflow-hidden">
            
            <div class="w-full md:w-3/5 bg-black flex items-center justify-center relative group">
                <% if (post.image.match(/\.(mp4|mov|avi|mkv|webm)$/i)) { %>
                    <video src="<%= post.image %>" controls class="max-h-full w-full object-contain"></video>
                <% } else { %>
                    <img src="<%= post.image %>" class="max-h-full w-full object-contain">
                <% } %>
            </div>

            <div class="w-full md:w-2/5 flex flex-col bg-white">
                <div class="p-4 border-b flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <img src="<%= post.user.profilePic %>" class="w-8 h-8 rounded-full border object-cover">
                        <span class="font-bold text-sm hover:underline cursor-pointer"><%= post.user.username %></span>
                    </div>
                    <button class="font-bold text-lg">⋮</button>
                </div>

                <div class="flex-grow p-4 overflow-y-auto no-scrollbar text-sm space-y-4">
                    <div class="flex gap-3">
                        <img src="<%= post.user.profilePic %>" class="w-8 h-8 rounded-full flex-shrink-0 object-cover">
                        <p><span class="font-bold mr-2"><%= post.user.username %></span><%= post.caption %></p>
                    </div>
                    
                    <hr class="border-gray-100">
                    
                    <div class="text-gray-400 text-center py-10">
                        Comments coming soon...
                    </div>
                </div>

                <div class="p-4 border-t border-gray-100">
                    <div class="flex gap-4 mb-2">
                        <button class="text-2xl hover:opacity-50 transition">❤️</button>
                        <button class="text-2xl hover:opacity-50 transition">💬</button>
                        <button class="text-2xl hover:opacity-50 transition">✈️</button>
                    </div>
                    <p class="font-bold text-xs mb-1"><%= post.likes.length %> likes</p>
                    <p class="text-[10px] text-gray-400 uppercase tracking-tight">
                        <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric' }) %>
                    </p>
                </div>

                <div class="p-4 border-t flex items-center gap-3">
                    <input type="text" placeholder="Add a comment..." class="flex-grow outline-none text-sm bg-transparent">
                    <button class="text-blue-500 font-bold text-sm disabled:opacity-50">Post</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>